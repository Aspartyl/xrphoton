{
  "version": 5,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 24,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "debug",
      "displayName": "Debug",
      "description": "Debug build with Vulkan validation requested",
      "binaryDir": "${sourceDir}/build/debug",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "XRPHOTON_ENABLE_VALIDATION": "ON"
      }
    },
    {
      "name": "release",
      "displayName": "Optimized",
      "description": "RelWithDebInfo build without Vulkan validation",
      "binaryDir": "${sourceDir}/build/release",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "RelWithDebInfo",
        "XRPHOTON_ENABLE_VALIDATION": "OFF"
      }
    },
    {
      "name": "ogfx-core",
      "displayName": "OGFx Core Only",
      "description": "Build and test the offline OGFx core without graphics dependencies",
      "binaryDir": "${sourceDir}/build/ogfx-core",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "BUILD_TESTING": "ON",
        "XRPHOTON_BUILD_ENGINE": "OFF"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "debug",
      "displayName": "Build Debug",
      "configurePreset": "debug",
      "configuration": "Debug"
    },
    {
      "name": "release",
      "displayName": "Build Optimized",
      "configurePreset": "release",
      "configuration": "RelWithDebInfo"
    },
    {
      "name": "ogfx-core",
      "displayName": "Build OGFx Core Only",
      "configurePreset": "ogfx-core",
      "configuration": "Debug"
    }
  ],
  "testPresets": [
    {
      "name": "ogfx-core",
      "displayName": "Test OGFx Core",
      "configurePreset": "ogfx-core",
      "output": {
        "outputOnFailure": true
      }
    }
  ]
}
